generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARES
}

enum BudgetModel {
  PERSONAL_SHARE
  NET_PAYMENT
}

enum ExpenseCategory {
  FOOD
  TRANSPORT
  ACCOMMODATION
  ENTERTAINMENT
  SHOPPING
  GROCERIES
  UTILITIES
  HEALTH
  TRAVEL
  OTHER
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  username            String?   @unique
  usernameChangedAt   DateTime?
  passwordHash        String
  avatar              String?
  isAdmin             Boolean   @default(false)
  isBanned            Boolean   @default(false)
  totalMonthlyBudget  Decimal?    @db.Decimal(12, 2)
  budgetModel         BudgetModel @default(NET_PAYMENT)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime  @updatedAt

  memberships         GroupMember[]
  invitesSent         GroupInvite[]       @relation("InvitedBy")
  expensesPaid        Expense[]           @relation("ExpensePayer")
  expenseSplits       ExpenseSplit[]      @relation("ExpenseSplitUser")
  settlementsSent     Settlement[]        @relation("SettlementSender")
  settlementsRecvd    Settlement[]        @relation("SettlementReceiver")
  directParticipation DirectParticipant[] @relation("DirectParticipantUser")
  friendships         Friendship[]        @relation("FriendshipUser")
  friendOf            Friendship[]        @relation("FriendshipFriend")
  friendInvitesSent   FriendInvite[]      @relation("FriendInviteOwner")
  friendRequestsSent  FriendRequest[]     @relation("FriendRequestSent")
  friendRequestsRecvd FriendRequest[]     @relation("FriendRequestReceived")
  pushSubscriptions   PushSubscription[]
  budgets             Budget[]
  ownedGroups         Group[]             @relation("GroupOwner")
}

model Group {
  id                 String    @id @default(cuid())
  name               String
  emoji              String?
  description        String?
  currency           String    @default("INR")
  ownerId            String
  allowMemberInvites Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  owner       User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members     GroupMember[]
  invites     GroupInvite[]
  expenses    Expense[]
  settlements Settlement[]
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  role     Role     @default(MEMBER)
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

model GroupInvite {
  id          String    @id @default(cuid())
  token       String    @unique
  groupId     String
  invitedById String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedBy User  @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([groupId])
  @@index([token])
}

model Expense {
  id          String          @id @default(uuid())
  // Nullable: a null groupId marks a *direct* (non-group) expense whose
  // members live in DirectParticipant instead of GroupMember.
  groupId     String?
  payerId     String
  description String
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory @default(OTHER)
  splitType   SplitType       @default(EQUAL)
  notes       String?
  receiptUrl  String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  group        Group?              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer        User                @relation("ExpensePayer", fields: [payerId], references: [id])
  splits       ExpenseSplit[]
  participants DirectParticipant[]

  // Most reads filter by group and exclude soft-deleted rows, sorted by date.
  @@index([groupId, deletedAt, date])
  @@index([payerId])
  // Direct-expense reads filter on (null) groupId + soft-delete, sorted by date.
  @@index([deletedAt, date])
}

// Participants of a *direct* (non-group) expense. Group expenses derive member
// identity from GroupMember; direct expenses derive it from these rows.
model DirectParticipant {
  id        String @id @default(cuid())
  expenseId String
  userId    String

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation("DirectParticipantUser", fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@index([userId])
}

model ExpenseSplit {
  id        String  @id @default(cuid())
  expenseId String
  userId    String
  amount    Decimal @db.Decimal(12, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation("ExpenseSplitUser", fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@index([userId])
}

model Settlement {
  id         String   @id @default(cuid())
  // Nullable: a null groupId marks a *direct* settlement between two users that
  // isn't tied to any group.
  groupId    String?
  senderId   String // the debtor who paid
  receiverId String // the creditor who was paid
  amount     Decimal  @db.Decimal(12, 2)
  note       String?
  createdAt  DateTime @default(now())

  group    Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender   User   @relation("SettlementSender", fields: [senderId], references: [id])
  receiver User   @relation("SettlementReceiver", fields: [receiverId], references: [id])

  @@index([groupId])
  // Direct settlements are looked up by the two parties.
  @@index([senderId, receiverId])
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user   User @relation("FriendshipUser",   fields: [userId],   references: [id], onDelete: Cascade)
  friend User @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())

  sender   User @relation("FriendRequestSent",     fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("FriendRequestReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model FriendInvite {
  id          String   @id @default(cuid())
  token       String   @unique
  invitedById String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  invitedBy User @relation("FriendInviteOwner", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([invitedById])
  @@index([token])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Budget {
  id        String          @id @default(cuid())
  userId    String
  category  ExpenseCategory
  amount    Decimal         @db.Decimal(12, 2)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
}
