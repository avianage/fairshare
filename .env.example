# Database
DATABASE_URL="postgresql://user:password@localhost:5432/fairshare"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Receipt uploads — directory OUTSIDE the web root (not publicly served)
UPLOAD_DIR="./uploads"

# Optional: surfaced by /api/health (e.g. git SHA or release tag). Defaults to "unknown".
APP_VERSION="dev"

# Anthropic API key for natural-language expense parsing (/api/expenses/parse)
ANTHROPIC_API_KEY=""
