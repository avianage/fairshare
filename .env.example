# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/fairshare"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Uploads ──────────────────────────────────────────────────────────────────
# Directory OUTSIDE the web root — must NOT be publicly served.
UPLOAD_DIR="./uploads"

# ─── Misc ─────────────────────────────────────────────────────────────────────
# Surfaced by /api/health (e.g. git SHA or release tag). Defaults to "unknown".
APP_VERSION="dev"

# The PWA service worker is enabled in `next dev` by default so it can be tested
# locally. Every file save regenerates sw.js and the SW re-activates, which can
# cause continuous page refreshing while you're actively coding. Set this to
# "true" locally to disable it; leave unset/false for production. Must be
# NEXT_PUBLIC_ — the client also reads it to actively unregister any leftover
# service worker + caches from a previous session (see ServiceWorkerRegistrar.tsx).
NEXT_PUBLIC_DISABLE_PWA="true"

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Natural-language expense parsing (/api/expenses/parse). Leave blank to disable.
ANTHROPIC_API_KEY=""

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate once: npx web-push generate-vapid-keys
# Never rotate unless your keys are compromised — existing subscriptions break.
#
# NEXT_PUBLIC_VAPID_PUBLIC_KEY  → passed as a Docker build ARG so Next.js
#                                  embeds it in the client bundle at build time.
#                                  Also kept here as a runtime env var for the
#                                  /api/notifications/vapid-public-key endpoint.
#
# VAPID_PUBLIC_KEY              → server-side alias (same value). Used by
#                                  lib/push.ts (web-push) and the subscribe API.
#
# VAPID_PRIVATE_KEY             → server/runtime ONLY. NEVER a build ARG.
#                                  Keep this out of source control.
#
# For local dev both vars should be set.
# For Docker: NEXT_PUBLIC_VAPID_PUBLIC_KEY and VAPID_PUBLIC_KEY must hold the
# same value; VAPID_PRIVATE_KEY is injected at runtime via docker-compose.yml.

NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
